## Stage 1: Build admin React app
FROM node:20-slim AS admin-builder

WORKDIR /app/admin

COPY src/admin/package.json src/admin/package-lock.json* ./
RUN npm install

COPY src/admin/ .
RUN npm run build

## Stage 2: Python backend
FROM python:3.11-slim

WORKDIR /app

# Minimal build toolchain for any pip dependency that compiles C/C++ extensions
# (PyStemmer, some sentence-transformers transitive deps). Without this the
# python:3.11-slim image can't build wheels that don't ship pre-built binaries,
# and pip install fails with exit code 1. Removed from the final image size
# via the pip --no-cache-dir; apt cache is also scrubbed.
RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
    && rm -rf /var/lib/apt/lists/*

# Install PyTorch CPU-only first so sentence-transformers doesn't drag in
# the ~5 GB CUDA/NVIDIA stack (HRDD pattern). Must come BEFORE requirements.txt.
RUN pip install --no-cache-dir torch --index-url https://download.pytorch.org/whl/cpu

# Backend dependencies
COPY src/backend/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Pre-download the embedding + reranker weights so first query doesn't hit
# HuggingFace (predictable cold start, works air-gapped).
#  - BGE-M3 embedder (~2.2 GB, 1024-dim multilingual)
#  - bge-reranker-v2-m3 cross-encoder (~568 M params, multilingual)
# Cached in /root/.cache/huggingface/. Also downloads MiniLM as a fallback
# in case rag_embedding_model is overridden back to it via deployment_backend.json.
RUN python -c "\
from sentence_transformers import SentenceTransformer, CrossEncoder; \
SentenceTransformer('BAAI/bge-m3'); \
SentenceTransformer('sentence-transformers/all-MiniLM-L6-v2'); \
CrossEncoder('BAAI/bge-reranker-v2-m3')\
"

# Application code
COPY src/backend/ ./src/
COPY config/deployment_backend.json ./config/deployment_backend.json

# Built admin SPA (served as fallback by FastAPI)
COPY --from=admin-builder /app/admin/dist /app/admin/dist

# Persistent data dir (mounted from a Docker volume in compose)
RUN mkdir -p /app/data

EXPOSE 8000

CMD ["uvicorn", "src.main:app", "--host", "0.0.0.0", "--port", "8000"]
